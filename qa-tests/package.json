{
  "name": "dpstore-qa-tests",
  "version": "1.0.0",
  "description": "QA Automation Test Suite for Medusa.js v2 and N-Genius payment gateway integration",
  "main": "index.js",
  "scripts": {
    "test:smoke": "jest --config=jest.config.js --runInBand --selectProjects smoke --json --outputFile=reports/test-report.json",
    "test:payment": "jest --config=jest.config.js --runInBand --selectProjects payment --json --outputFile=reports/test-report.json",
    "test:webhook": "jest --config=jest.config.js --runInBand --selectProjects webhook --json --outputFile=reports/test-report.json",
    "test:inventory": "jest --config=jest.config.js --runInBand --selectProjects inventory --json --outputFile=reports/test-report.json",
    "test:security": "jest --config=jest.config.js --runInBand --selectProjects security --json --outputFile=reports/test-report.json",
    "test:all": "jest --config=jest.config.js --runInBand --forceExit --json --outputFile=reports/test-report.json"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.9",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.10.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
